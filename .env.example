# ================================================
# Starizzi Shop Bot - Cấu hình môi trường
# ================================================
# Copy file này thành .env và điền thông tin:
#   cp .env.example .env
# ================================================

# Telegram Bot Token (lấy từ @BotFather trên Telegram)
BOT_TOKEN=your_bot_token_here

# Admin Telegram ID (gửi /myid cho bot để lấy ID)
ADMIN_ID=your_telegram_id_here

# ================================================
# Ngân hàng 1 (bắt buộc) - Thanh toán QR VietQR
# ================================================
# Tra mã BIN tại: https://www.vietqr.io/danh-sach-ngan-hang
BANK_BIN=970422
BANK_ACCOUNT=your_bank_account_number
BANK_ACCOUNT_NAME=YOUR_FULL_NAME
BANK_NAME=MB

# ================================================
# Ngân hàng 2 (tùy chọn - cho khách chọn bank)
# ================================================
# Bỏ comment để bật ngân hàng thứ 2
# BANK2_BIN=970436
# BANK2_ACCOUNT=your_second_bank_account
# BANK2_ACCOUNT_NAME=YOUR_FULL_NAME
# BANK2_NAME=VCB

# ================================================
# Thanh toán tự động (tùy chọn)
# ================================================
# SEPAY_API_KEY=your_sepay_api_key
WEBHOOK_PORT=3000

# ================================================
# Thông tin Shop
# ================================================
SHOP_NAME=My Shop
SUPPORT_CONTACT=@your_telegram_username

# ================================================
# Google Sheet Sync (tùy chọn)
# ================================================
# 1. Mở Google Sheet → File → Chia sẻ → Xuất bản lên web → Xuất bản
# 2. Copy Sheet ID từ URL: docs.google.com/spreadsheets/d/[SHEET_ID]/edit
# GOOGLE_SHEET_ID=your_google_sheet_id
# SHEET_SYNC_INTERVAL=5
